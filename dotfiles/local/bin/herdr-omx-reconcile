#!/usr/bin/env python3
"""Reconcile Herdr OMX pane states from tmux/OMX session bindings.

Rules:
- Prefer explicit HERDR_PANE_ID + OMX_SESSION_ID + OMX_ROOT from tmux env.
- If HERDR_PANE_ID is missing, bind only by deterministic tmux client tty ->
  Herdr pane spawn pid/session.json mapping; never use focus/cwd/visible history/title spinners.
- Read only that session's OMX_ROOT/.omx/state/sessions/OMX_SESSION_ID table.
- Codex turn lifecycle state decides busy/blocked/idle. OMX mode files are label
  metadata only; stale active workflow files must not make an idle Codex tab
  appear working.
"""
import json, os, re, subprocess, time, sys, socket, random
from pathlib import Path

EXCLUDE = {"hud-state.json", "prompt-routing-state.json", "notify-hook-state.json", "herdr-omx-turn-state.json"}
STALE_TURN_SECONDS = 6 * 60 * 60
FINISH_TTL_SECONDS = 30

def run(argv, timeout=1.0):
    try:
        return subprocess.run(argv, text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, timeout=timeout)
    except Exception:
        return None

def tmux_env(session):
    proc=run(["tmux","show-environment","-t",session], timeout=0.8)
    env={}
    if not proc or proc.returncode!=0:
        return env
    for line in proc.stdout.splitlines():
        if "=" in line and not line.startswith("-"):
            k,v=line.split("=",1)
            env[k]=v
    return env

def read_json(path):
    try:
        with open(path, encoding='utf-8') as f: return json.load(f)
    except Exception:
        return None

def first_state_root(omx_root, sid):
    if not omx_root or not sid:
        return None
    root = Path(omx_root)/'.omx'/'state'/'sessions'/sid
    return root if root.is_dir() else None

def turn_status(root):
    if not root:
        return None, None, False, '', None
    data = read_json(root/'herdr-omx-turn-state.json')
    if not isinstance(data, dict):
        return None, None, False, '', None
    updated = float(data.get('updated_monotonic') or 0)
    age = (time.monotonic() - updated) if updated else None
    event = str(data.get('event') or '')
    if age is not None and age > STALE_TURN_SECONDS:
        # Preserve the fact that a turn-state file exists. Reconcile may use a
        # live tmux title spinner only for truly legacy sessions with no hook
        # turn-state at all; stale titles must not resurrect an idle tab.
        return None, None, False, event, age
    state = data.get('state')
    label = data.get('custom_status') or data.get('label')
    if state in ('working','blocked','idle'):
        return state, label, True, event, age
    return None, None, False, event, age

def label_for(mode, data):
    phase=None
    if isinstance(data, dict):
        phase=data.get('current_phase') or data.get('phase') or data.get('status')
        story=data.get('current_story') or data.get('story') or data.get('goal_id') or data.get('current_goal')
        if story and phase: return f"{mode}:{phase}:{str(story)[:48]}"
        if phase: return f"{mode}:{phase}"
    return str(mode)

def summarize(omx_root, sid):
    labels=[]
    root = first_state_root(omx_root, sid)
    state, turn_label, turn_known, turn_event, turn_age = turn_status(root)
    if state in ('working','blocked'):
        return state, (turn_label or ('OMX waiting for user' if state == 'blocked' else 'OMX working')), turn_known, turn_event, turn_age
    roots=[]
    if root:
        roots.append(root)
    for root in roots:
        if not root.is_dir():
            continue
        skill=read_json(root/'skill-active-state.json')
        if isinstance(skill, dict):
            active_skills=skill.get('active_skills')
            if isinstance(active_skills, list):
                for item in active_skills:
                    if isinstance(item, dict) and item.get('active') is True:
                        name=item.get('skill') or skill.get('skill') or skill.get('initialized_mode') or 'omx'
                        phase=item.get('phase') or skill.get('phase')
                        labels.append(f"{name}:{phase}" if phase else str(name))
            if skill.get('active') is True and not labels:
                name=skill.get('skill') or skill.get('initialized_mode') or 'omx'
                phase=skill.get('phase')
                labels.append(f"{name}:{phase}" if phase else str(name))
        for path in sorted(root.glob('*-state.json')):
            if path.name in EXCLUDE or path.name == 'skill-active-state.json':
                continue
            data=read_json(path)
            if not isinstance(data, dict):
                continue
            mode=data.get('mode') or path.name[:-len('-state.json')]
            if data.get('active') is True:
                lab=label_for(mode, data)
                if lab not in labels: labels.append(lab)
    label = 'OMX ' + ', '.join(labels[:3]) if labels else 'OMX idle'
    # Active OMX mode files are only a label. Herdr's primary state is Codex
    # turn activity: no fresh working/blocked turn-state means idle.
    return 'idle', (turn_label or label), turn_known, turn_event, turn_age

def tmux_client_tty(session):
    proc=run(['tmux','list-clients','-t',session,'-F','#{client_tty}'], timeout=0.8)
    if proc and proc.returncode == 0:
        for line in proc.stdout.splitlines():
            line=line.strip()
            if line.startswith('/dev/pts/'):
                return line
    return ''

def live_panes():
    data = read_json_from_cmd(['herdr','pane','list']) or read_json_from_cmd(['herdr','pane','list','--json']) or {}
    if isinstance(data, dict) and isinstance(data.get('result'), dict):
        panes = data.get('result', {}).get('panes') or []
        return [p for p in panes if isinstance(p, dict)]
    return []

def build_live_public_resolver():
    """Return a resolver for Herdr local pane ids to live public pane ids.

    Herdr injects HERDR_PANE_ID as a terminal-local id (`p_6`). After restore or
    tab recreation, the live public pane id exposed by `herdr pane list` can be a
    different local number in the same tab (for example tab 4 restored from p_6
    but currently exposed as w...-5). Resolve through session.json tab identity
    plus the live pane list; never trust a stale direct `w...-N` unless it is
    present in the expected live tab.
    """
    panes = live_panes()
    live_by_id = {str(p.get('pane_id') or ''): p for p in panes if p.get('pane_id')}
    live_by_tab = {}
    for pane in panes:
        tab_id = str(pane.get('tab_id') or '')
        if tab_id:
            live_by_tab.setdefault(tab_id, []).append(pane)
    session_json=Path.home()/'.config'/'herdr'/'session.json'
    data=read_json(session_json)

    def resolve(wid, idx, local_id):
        direct = f'{wid}-{local_id}'
        expected_tab = f'{wid}:{idx}'
        direct_pane = live_by_id.get(direct)
        if direct_pane and str(direct_pane.get('tab_id') or '') == expected_tab:
            return direct
        tab_panes = live_by_tab.get(expected_tab) or []
        if len(tab_panes) == 1 and tab_panes[0].get('pane_id'):
            return str(tab_panes[0]['pane_id'])
        # Split tabs can legitimately have multiple live panes. In that case
        # direct mapping is safe only when it exists in the live list; otherwise
        # there is no deterministic replacement for a missing local pane.
        if direct_pane:
            return direct
        return ''

    out={}
    if isinstance(data, dict):
        for ws in data.get('workspaces') or []:
            wid=ws.get('id')
            if not wid:
                continue
            for idx,tab in enumerate(ws.get('tabs') or [], start=1):
                keys=set(str(k) for k in (tab.get('panes') or {}).keys())
                root=tab.get('root_pane')
                focused=tab.get('focused')
                if root is not None: keys.add(str(root))
                if focused is not None: keys.add(str(focused))
                tab_public_fallback=''
                for candidate in (focused, root):
                    if candidate is not None:
                        tab_public_fallback = resolve(wid, idx, str(candidate))
                        if tab_public_fallback:
                            break
                for key in keys:
                    public = resolve(wid, idx, key)
                    if public:
                        out[key]=public
                        out[f'p_{key}']=public
                if tab_public_fallback:
                    out[f'{wid}:{idx}']=tab_public_fallback
    return out, panes

def pane_spawn_pid_map():
    session_json=Path.home()/'.config'/'herdr'/'session.json'
    data=read_json(session_json)
    wanted=set()
    if isinstance(data, dict):
        for ws in data.get('workspaces') or []:
            for tab in ws.get('tabs') or []:
                for local_id in (tab.get('panes') or {}).keys():
                    wanted.add(str(local_id))
    if not wanted:
        return {}
    log=Path.home()/'.config'/'herdr'/'herdr-server.log'
    mapping={}
    try:
        for line in log.read_text(errors='ignore').splitlines():
            m=re.search(r'pane child spawned .*pane_id=(\d+) pid=(\d+)', line)
            if m and m.group(1) in wanted:
                mapping[m.group(1)] = int(m.group(2))
    except Exception:
        pass
    local_map,_ = build_live_public_resolver()
    out={}
    if isinstance(data, dict):
        for ws in data.get('workspaces') or []:
            wid=ws.get('id')
            if not wid:
                continue
            for idx,tab in enumerate(ws.get('tabs') or [], start=1):
                tab_public_fallback = local_map.get(f'{wid}:{idx}')
                for local_id in (tab.get('panes') or {}).keys():
                    local_id = str(local_id)
                    pid=mapping.get(local_id)
                    public=local_map.get(local_id) or tab_public_fallback or ''
                    if pid and public:
                        out[pid]=public
                if tab_public_fallback:
                    out[f'{wid}:{idx}']=tab_public_fallback
    return out


def herdr_local_pane_id_map():
    """Map Herdr injected local pane ids to currently live public pane ids."""
    local_map,_ = build_live_public_resolver()
    return local_map


def tty_foreground_root_pid(tty):
    if not tty.startswith('/dev/'):
        return None
    short=tty.replace('/dev/','')
    proc=run(['ps','-t',short,'-o','pid=,ppid=,stat=,cmd='], timeout=0.8)
    if not proc or proc.returncode != 0:
        return None
    rows=[]
    for line in proc.stdout.splitlines():
        parts=line.strip().split(None,3)
        if len(parts) >= 4:
            try: rows.append((int(parts[0]), int(parts[1]), parts[2], parts[3]))
            except Exception: pass
    if not rows:
        return None
    pids={r[0] for r in rows}
    roots=[r for r in rows if r[1] not in pids]
    return roots[0][0] if roots else rows[0][0]

def infer_pane_from_client_tty(session, pid_map):
    tty=tmux_client_tty(session)
    root_pid=tty_foreground_root_pid(tty) if tty else None
    if root_pid and root_pid in pid_map:
        return pid_map[root_pid]
    return ''

def session_active_pane_tty(session):
    proc=run(['tmux','list-panes','-t',session,'-F','#{pane_active} #{pane_tty}'], timeout=0.8)
    if proc and proc.returncode == 0:
        for line in proc.stdout.splitlines():
            if line.startswith('1 '):
                tty=line[2:].strip()
                if tty.startswith('/dev/pts/'):
                    return tty
    return ''

def pids_on_tty(tty):
    if not tty.startswith('/dev/'):
        return []
    short=tty.replace('/dev/','')
    proc=run(['ps','-t',short,'-o','pid='], timeout=0.8)
    if not proc or proc.returncode != 0:
        return []
    out=[]
    for line in proc.stdout.splitlines():
        try: out.append(int(line.strip()))
        except Exception: pass
    return out

def proc_env(pid):
    try:
        raw=Path(f'/proc/{pid}/environ').read_bytes().decode(errors='ignore').split('\0')
    except Exception:
        return {}
    env={}
    for item in raw:
        if '=' in item:
            k,v=item.split('=',1)
            env[k]=v
    return env

def session_omx_process_env(session, local_pane_map):
    # OMX_SESSION_ID/OMX_ROOT often live on the Codex child process rather than
    # tmux's session environment. Read only processes in this tmux session's
    # active pane TTY, and prefer the one that has both OMX identifiers.
    tty=session_active_pane_tty(session)
    best={}
    for pid in pids_on_tty(tty):
        env=proc_env(pid)
        if env.get('OMX_SESSION_ID') and env.get('OMX_ROOT'):
            best=env
        elif not best and env.get('HERDR_PANE_ID'):
            best=env
    if not best:
        return {}
    out={}
    for key in ('OMX_SESSION_ID','OMX_ROOT','HERDR_PANE_ID'):
        if best.get(key):
            out[key]=best[key]
    if out.get('HERDR_PANE_ID'):
        out['HERDR_PANE_ID']=local_pane_map.get(out['HERDR_PANE_ID'], out['HERDR_PANE_ID'])
    return out

def pane_exists(pid):
    proc=run(['herdr','pane','get',pid], timeout=0.8)
    return bool(proc and proc.returncode==0)

SPINNER_CHARS = tuple('⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏')

def session_active_title(session):
    proc=run(['tmux','list-panes','-t',session,'-F','#{pane_active} #{pane_title}'], timeout=0.8)
    if proc and proc.returncode == 0:
        for line in proc.stdout.splitlines():
            if line.startswith('1 '):
                return line[2:]
    return ''

def session_has_live_spinner(session):
    # Legacy-session fallback only: old OMX panes may predate hook turn-state.
    # Do not use this when a fresh hook turn-state exists; short completed turns
    # can leave stale visible/title artifacts.
    title=session_active_title(session).strip()
    return bool(title and title[0] in SPINNER_CHARS)

def herdr_socket_path():
    data = read_json_from_cmd(['herdr','status','server','--json'])
    if isinstance(data, dict) and data.get('socket'):
        return data.get('socket')
    return str(Path.home()/'.config'/'herdr'/'herdr.sock')

def read_json_from_cmd(argv):
    proc=run(argv, timeout=0.8)
    if proc and proc.returncode == 0 and proc.stdout.strip():
        try: return json.loads(proc.stdout)
        except Exception: return None
    return None

def release_agent(pid):
    # Herdr turns a direct working->idle report into UI `done` for attention.
    # For the OMX status bridge the user-facing resting state should be `idle`,
    # so clear the previous OMX authority through Herdr's socket API before
    # writing idle. The CLI exposes no release-agent subcommand.
    path = herdr_socket_path()
    req = {
        'id': f'herdr:omx:release:{time.time_ns()}:{random.randrange(1_000_000)}',
        'method': 'pane.release_agent',
        'params': {'pane_id': pid, 'source': 'herdr:omx', 'agent': 'omx', 'seq': time.time_ns()},
    }
    try:
        client = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        client.settimeout(0.5)
        client.connect(path)
        client.sendall((json.dumps(req) + '\n').encode())
        try: client.recv(4096)
        except Exception: pass
        client.close()
    except Exception:
        pass

def report(pid, sid, state, label, release_idle=False):
    if state == 'idle' and release_idle:
        release_agent(pid)
    cmd=['herdr','pane','report-agent',pid,'--source','herdr:omx','--agent','omx','--state',state,'--message',label,'--custom-status',label,'--seq',str(time.time_ns())]
    if sid: cmd += ['--agent-session-id', sid]
    proc=run(cmd, timeout=1.0)
    return bool(proc and proc.returncode==0)

def main():
    if not run(['command','-v','tmux']):
        pass
    proc=run(['tmux','list-sessions','-F','#{session_name}'], timeout=1.0)
    if not proc or proc.returncode!=0:
        return 0
    count=0
    pid_map=pane_spawn_pid_map()
    local_pane_map=herdr_local_pane_id_map()
    for session in proc.stdout.splitlines():
        if not session.startswith('omx-'):
            continue
        env=tmux_env(session)
        proc_env_fallback=session_omx_process_env(session, local_pane_map)
        explicit_pid=env.get('HERDR_PANE_ID') or proc_env_fallback.get('HERDR_PANE_ID')
        sid=env.get('OMX_SESSION_ID') or proc_env_fallback.get('OMX_SESSION_ID')
        root=env.get('OMX_ROOT') or proc_env_fallback.get('OMX_ROOT')
        env_pid=local_pane_map.get(explicit_pid or '', explicit_pid or '')
        inferred_pid=infer_pane_from_client_tty(session, pid_map)
        if not inferred_pid:
            # If tmux client tty -> spawn pid cannot be recovered from logs, use
            # the attached shell's HERDR_PANE_ID env. This is still deterministic
            # and Herdr-owned; it supports both public ids and new `p_N` ids.
            tty=tmux_client_tty(session)
            root_pid=tty_foreground_root_pid(tty) if tty else None
            if root_pid:
                try:
                    raw_env=Path(f'/proc/{root_pid}/environ').read_bytes().decode(errors='ignore').split('\0')
                    for item in raw_env:
                        if item.startswith('HERDR_PANE_ID='):
                            inferred_pid=local_pane_map.get(item.split('=',1)[1], item.split('=',1)[1])
                            break
                except Exception:
                    pass
        # Attached tmux client tty -> Herdr spawn pid is stronger than old tmux
        # HERDR_PANE_ID env. Stale explicit env values caused different OMX
        # sessions to overwrite the same Herdr tab.
        if inferred_pid:
            pid=inferred_pid
            if explicit_pid != inferred_pid:
                run(['tmux','set-environment','-t',session,'HERDR_PANE_ID',pid], timeout=0.8)
        else:
            # If the session is attached but its client tty is not a current Herdr
            # pane spawn tree, do not trust a stale explicit binding.
            if tmux_client_tty(session):
                if explicit_pid:
                    run(['tmux','set-environment','-u','-t',session,'HERDR_PANE_ID'], timeout=0.8)
                pid=''
            else:
                pid=env_pid or ''
        if pid:
            if sid:
                run(['tmux','set-environment','-t',session,'OMX_SESSION_ID',sid], timeout=0.8)
            if root:
                run(['tmux','set-environment','-t',session,'OMX_ROOT',root], timeout=0.8)
        if not pid or not sid or not root:
            continue
        if not pane_exists(pid):
            continue
        state,label,turn_known,turn_event,turn_age=summarize(root,sid)
        if state == 'idle' and not turn_known and not turn_event and session_has_live_spinner(session):
            state='working'
            if label == 'OMX idle':
                label='OMX working'
        # Fresh Stop should be reported as a normal idle transition so Herdr can
        # show its first-class finish/done attention state. After a short TTL,
        # watcher reconciliation clears that attention state back to stable idle.
        fresh_stop = bool(turn_known and state == 'idle' and turn_event.lower() == 'stop' and turn_age is not None and turn_age < FINISH_TTL_SECONDS)
        release_idle = bool(state == 'idle' and not fresh_stop)
        if report(pid,sid,state,label,release_idle=release_idle):
            count+=1
    if os.environ.get('HERDR_OMX_RECONCILE_DEBUG'):
        print(json.dumps({'reconciled':count}, ensure_ascii=False))
    return 0

if __name__ == '__main__':
    raise SystemExit(main())
