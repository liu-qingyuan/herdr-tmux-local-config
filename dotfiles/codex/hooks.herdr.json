{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.codex/herdr-agent-state.sh\" idle",
            "timeout": 10,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.codex/herdr-omx-state.sh\"",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.codex/herdr-agent-state.sh\" working",
            "timeout": 10,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.codex/herdr-omx-state.sh\"",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.codex/herdr-omx-state.sh\"",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.codex/herdr-agent-state.sh\" working",
            "timeout": 10,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.codex/herdr-omx-state.sh\"",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.codex/herdr-omx-state.sh\"",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.codex/herdr-omx-state.sh\"",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.codex/herdr-agent-state.sh\" idle",
            "timeout": 10,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.codex/herdr-omx-state.sh\"",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ]
  }
}
